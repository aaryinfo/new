# ═══════════════════════════════════════════════════════
#  NSE F&O Scanner — Environment Variables
#  Copy this file to .env and fill in your values
#  NEVER commit .env to git
# ═══════════════════════════════════════════════════════

# ── MongoDB (optional — falls back to CSV file storage) ──────
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/scanner

# ── AI Agent: Claude (optional) ──────────────────────
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── AI Agent: Zerodha (optional — paper mode default) ─
KITE_API_KEY=your_kite_api_key
KITE_ACCESS_TOKEN=your_daily_access_token
