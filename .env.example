# ═══════════════════════════════════════════════════════
#  NSE F&O Scanner — Environment Variables
#  Copy this file to .env and fill in your values
#  NEVER commit .env to git
# ═══════════════════════════════════════════════════════

# ── Supabase (REQUIRED for auth) ─────────────────────
# Get from: https://supabase.com → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=eyJhbGc...your_anon_key_here
SUPABASE_SERVICE_KEY=eyJhbGc...your_service_role_key_here
SUPABASE_JWT_SECRET=your_jwt_secret_from_supabase_dashboard

# ── Admin ─────────────────────────────────────────────
# This email gets ADMIN role — must match Supabase user email
ADMIN_EMAIL=admin@yourdomain.com

# ── MongoDB (optional — falls back to in-memory) ──────
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/scanner

# ── AI Agent: Claude (optional) ──────────────────────
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── AI Agent: Zerodha (optional — paper mode default) ─
KITE_API_KEY=your_kite_api_key
KITE_ACCESS_TOKEN=your_daily_access_token
